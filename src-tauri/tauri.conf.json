{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "LowCal",
  "version": "0.5.2",
  "identifier": "dev.lowcal.terminal-orchestrator",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "My LowCal Environment",
        "width": 1280,
        "height": 840,
        "minWidth": 1040,
        "minHeight": 520,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/64x64.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "copyright": "",
    "shortDescription": "",
    "longDescription": "",
    "macOS": {
      "bundleName": "LowCal"
    }
  }
}
